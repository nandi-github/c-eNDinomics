  "readme": {
    "purpose": "Named macro shock scenario presets selectable from the UI. Each preset defines a deterministic stress-test applied on top of Monte Carlo returns. System file \u2014 lives in src/config/, not per-profile.",
    "how_selected": "User picks a preset name in the UI ('average', 'below_average', 'bad', 'worst', or 'none'). The simulator loads the matching preset from this file. Profile shocks_yearly.json can augment or replace the preset.",
    "preset_names": {
      "none": "No system shock applied. Pure Monte Carlo only.",
      "average": "Mild correction \u2014 brief dip, quick recovery. Roughly 10% drawdown.",
      "below_average": "Moderate downturn \u2014 2011-style correction, slower recovery. ~20% drawdown.",
      "bad": "Significant recession \u2014 2001 dotcom style, broad decline. ~35% drawdown.",
      "worst": "Severe crash \u2014 2008 GFC style, deep and prolonged. ~50%+ drawdown."
    },
    "preset_fields": {
      "description": "Human-readable label shown in the UI dropdown.",
      "mode": "Always 'override' for system presets \u2014 replaces stochastic returns for affected classes during the shock window.",
      "events": "List of shock events. Same schema as shocks_yearly.json events. See that file's readme for full field documentation."
    },
    "adding_presets": "Add a new named object under 'presets'. The UI dropdown will pick it up automatically. Preset names must be lowercase with underscores.",
    "do_not_rename_existing": "The UI and api.py reference preset names by string. Renaming 'bad' or 'worst' will break the dropdown without a matching api.py update."
  }
