  "readme": {
    "purpose": "Per-ticker return/volatility assumptions and distribution characteristics used by the Monte Carlo simulator. Auto-regenerated by refresh_assets.py from live Yahoo Finance data on server startup if older than STALE_DAYS. Manual edits will be overwritten on next refresh unless you disable auto-refresh in api.py.",
    "auto_refresh": "Managed by refresh_assets.py. To force a refresh: python refresh_assets.py --out src/config/assets.json --days 0. To skip refresh: set SKIP_ASSET_REFRESH=1 env var.",
    "asset_classes": "Valid class values: 'US_STOCKS', 'INTL_STOCKS', 'GOLD', 'COMMOD', 'LONG_TREAS', 'INT_TREAS', 'TIPS', 'CASH'. Class drives correlation matrix used in Monte Carlo, not individual ticker returns.",
    "per_ticker_fields": {
      "class": "Asset class this ticker belongs to. Must match a class defined in assets_loader.py correlation matrix.",
      "mu_annual": "Expected annual log return (drift). E.g. 0.065 = ~6.5% annualized. Estimated from trailing history by refresh_assets.py. Override manually to express a personal view.",
      "sigma_annual": "Annual return volatility (standard deviation). E.g. 0.16 = 16% annualized. Higher = more Monte Carlo spread.",
      "expense_ratio": "Annual fee as a decimal. Subtracted from returns each year. E.g. 0.0003 = 0.03% (3 basis points). 0.0 for individual stocks.",
      "tracking_error": "Additional annual return noise for index funds vs their benchmark. ETFs: ~0.01. Individual stocks: ~0.02-0.04. Pure benchmark: 0.0.",
      "dist": {
        "yield_annual": "Annual distribution yield as a decimal. E.g. 0.018 = 1.8%. Used to compute taxable distributions each year in brokerage accounts.",
        "qualified_ratio": "Fraction of distributions that qualify for LTCG tax rates. E.g. 0.9 = 90% qualified. Treasuries: 0.0 (interest, not dividends). Commodities: 0.0."
      },
      "dist_note": "dist field is optional. If absent (e.g. GOLD, COMMOD), no taxable distributions are generated for that ticker."
    },
    "adding_tickers": "Add a new ticker entry manually OR let refresh_assets.py discover it from allocation_yearly.json holdings_pct entries. refresh_assets.py reads all profiles to find referenced tickers."
  }
}