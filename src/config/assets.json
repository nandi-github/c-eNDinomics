    "expense_ratio": "Annual fund fee subtracted from returns.",
    "tracking_error": "Additional annual noise above class model. 0.0 for pure index, 0.03-0.04 for single stocks.",
    "dist.yield_annual": "Annual distribution yield. Drives taxable income in brokerage accounts.",
    "dist.qualified_ratio": "Fraction of distributions taxed at LTCG rates. 0.0 for Treasury interest.",
    "_provenance": "Audit trail per ticker \u2014 basis for parameter choices. Ignored by simulator.",
    "auto_refresh_enabled": "false \u2014 asset model is now managed manually or by asset_calibration.py pipeline. Do not run refresh_assets.py against this file.",
    "correlations": "Class-level empirical long-run correlation matrix. Conservative (less than peak crisis correlations)."
