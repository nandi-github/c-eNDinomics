  "readme": {
    "purpose": "Portfolio structure: account definitions, starting balances, annual deposits, and asset allocation. 'global_allocation' is the default for all years. 'overrides' are time-bounded and revert to global_allocation after their range ends.",
    "accounts": {
      "name": "Unique account identifier used throughout all JSON files.",
      "type_options": "'taxable' (brokerage), 'traditional_ira' (pre-tax, RMD-subject), 'roth_ira' (post-tax, no RMD)"
    },
    "starting": "Starting balance in nominal dollars per account at simulation year 0.",
    "deposits_yearly": "Annual contributions per account per year range. In nominal dollars. IRA contribution limits are NOT enforced here \u2014 set to 0 if not contributing.",
    "global_allocation": {
      "purpose": "Default allocation for ALL years. Used for any year not covered by an override. Changing this affects the whole simulation unless overridden.",
      "portfolios": "Named portfolio buckets within an account. Weights must sum to 100 across all portfolios in the account.",
      "weight_pct": "Percentage of the account in this portfolio bucket. All portfolio weight_pct values for an account must sum to 100.",
      "classes_pct": {
        "purpose": "Asset class breakdown within a portfolio. Must sum to 100.",
        "available_classes": "US_STOCKS, INTL_STOCKS, GOLD, COMMOD, LONG_TREAS, INT_TREAS, TIPS, CASH"
      },
      "holdings_pct": "Optional. Specific ETF/fund tickers within each class. Must sum to 100 per class. Used for display and benchmark comparison only \u2014 does not affect simulation returns.",
      "rebalance_band_pct": "Optional per-portfolio override. Drift band as % of target weight before rebalancing triggers. Default: 10 (meaning \u00b110% of target). E.g. if target is 20%, band is 18%-22%."
    },
    "overrides": {
      "purpose": "Time-bounded allocation changes. After the years range ends, allocation reverts to global_allocation. No permanent overrides \u2014 update global_allocation instead.",
      "years": "Year range e.g. '7-10'. Year 1 = current_age + 1.",
      "mode_options": {
        "augment": "Merge with global_allocation \u2014 only specified accounts/portfolios/classes are changed, rest inherit from global.",
        "replace": "Full replacement \u2014 specified accounts completely override global_allocation for this period."
      }
    }
  }
}