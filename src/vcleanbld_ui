#!/usr/bin/env bash
# vcleanbld_ui — guaranteed full clean rebuild of the eNDinomics UI
# Always wipes everything and rebuilds from scratch. Zero ambiguity.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
UI_DIR="$SCRIPT_DIR/ui"
SRC_DIR="$UI_DIR/src"
DIST_DIR="$UI_DIR/dist"

echo "== eNDinomics UI Full Clean Build =="
echo ""

# ── Show source timestamps so you can confirm correct files are on disk ───────
echo "-- Source files being compiled --"
for f in "$SRC_DIR/App.tsx" "$SRC_DIR/styles.css" "$SRC_DIR/main.tsx"; do
    if [[ -f "$f" ]]; then
        mod=$(stat -f "%Sm" -t "%Y-%m-%d %H:%M:%S" "$f" 2>/dev/null \
              || stat --format="%y" "$f" 2>/dev/null | cut -d. -f1)
        echo "  $mod  $(basename $f)"
    else
        echo "  MISSING: $f  ← fix this before continuing"
        exit 1
    fi
done
echo ""

# ── Wipe Python bytecode cache (prevents stale .pyc from shadowing new code) ──
echo "-- Clearing Python __pycache__ --"
rm -rf "$SCRIPT_DIR/__pycache__"
echo "   done"

# ── Full UI wipe — no stale artifacts anywhere ────────────────────────────────
echo "-- Wiping dist/, node_modules/, package-lock.json --"
rm -rf "$DIST_DIR"
rm -rf "$UI_DIR/node_modules"
rm -f  "$UI_DIR/package-lock.json"
echo "   done"
echo ""

# ── Fresh install ─────────────────────────────────────────────────────────────
echo "-- npm install (fresh) --"
cd "$UI_DIR"
npm install

# ── Build ─────────────────────────────────────────────────────────────────────
echo ""
echo "-- npm run build --"
npm run build
cd "$SCRIPT_DIR"

# ── Verify ────────────────────────────────────────────────────────────────────
if [[ ! -f "$DIST_DIR/index.html" ]]; then
    echo ""
    echo "ERROR: dist/index.html not found — build failed"
    exit 1
fi

built_js=$(ls -t "$DIST_DIR/assets/"*.js 2>/dev/null | head -1 || true)
echo ""
echo "== Build complete =="
echo "   dist/index.html : OK"
if [[ -n "$built_js" ]]; then
    mod=$(stat -f "%Sm" -t "%Y-%m-%d %H:%M:%S" "$built_js" 2>/dev/null \
          || stat --format="%y" "$built_js" 2>/dev/null | cut -d. -f1)
    echo "   JS bundle       : $(basename $built_js)  (built $mod)"
fi
echo ""

# ── Start API server ──────────────────────────────────────────────────────────
echo "== Starting API server =="
python -m uvicorn api:app --reload
