# ===========================================================================
# eNDinomics .gitignore
# Rule: code goes to GitHub. User data stays local. Always.
# ===========================================================================

# ---------------------------------------------------------------------------
# USER DATA — NEVER push. Contains real financial data.
# ---------------------------------------------------------------------------

# All user accounts and their profiles (Stream 4+)
users/

# Current single-user profiles (pre-Stream 4)
# Exception: system/ and test accounts are allowed (see below)
profiles/*/
!profiles/default/
!profiles/__system__*/
!profiles/__testui__/

# Run artifacts — simulation results, snapshots (can be large + personal)
profiles/*/reports/
users/*/profiles/*/reports/

# Version history (personal data + timestamps)
profiles/*/versions.json
users/*/profiles/*/versions.json

# Session locks (runtime state)
users/*/session.lock

# ---------------------------------------------------------------------------
# SYSTEM PROFILES — safe to push (reference data, no personal info)
# ---------------------------------------------------------------------------
# profiles/default/           → already allowed above
# profiles/__system__*/       → already allowed above
# profiles/__testui__/        → already allowed above
# system/profiles/            → allowed (future multi-user structure)

# ---------------------------------------------------------------------------
# BUILD ARTIFACTS
# ---------------------------------------------------------------------------
ui/dist/
ui/node_modules/
ui/package-lock.json
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ---------------------------------------------------------------------------
# TEST ARTIFACTS
# ---------------------------------------------------------------------------
test_results/
# Exception: keep baseline file (it's code, not data)
!test_results/regression_baseline.json
playwright-report/
test-results/

# ---------------------------------------------------------------------------
# MARKET DATA CACHE (large, auto-regenerated)
# ---------------------------------------------------------------------------
market_data/cache/
market_data/*.pkl
market_data/*.parquet
market_signals.json

# ---------------------------------------------------------------------------
# PYTHON / VENV
# ---------------------------------------------------------------------------
venv/
.venv/
env/
.env/
*.egg-info/

# ---------------------------------------------------------------------------
# SECRETS — never ever
# ---------------------------------------------------------------------------
.env
.env.*
secrets.json
*_secret*
*_private*
auth_keys/

# ---------------------------------------------------------------------------
# OS / EDITOR NOISE
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# LOGS
# ---------------------------------------------------------------------------
*.log
uvicorn*.log
server.log

# Transient runtime data — never commit
src/profiles/*/reports/
src/profiles/*/.versions/
src/profiles/Experimental-*/
src/profiles/Test*/
src/profiles/__system__*/

# Profiles — only default is source-controlled
src/profiles/*/reports/
src/profiles/*/.versions/
src/profiles/[!d]*/
src/profiles/d[!e]*/

# Profiles — only default/ is source-controlled, everything else is runtime data
src/profiles/Experimental-*/
src/profiles/Test*/
src/profiles/__system__*/
src/profiles/*/reports/
src/profiles/*/.versions/

# Runtime data — never commit
src/profiles/Experimental-*/
src/profiles/Test*/
src/profiles/__system__*/
src/profiles/__testui__*/
src/profiles/*/reports/
src/profiles/*/.versions/
